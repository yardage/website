---
interface Props {
  teaser?: boolean;
}

const { teaser = false } = Astro.props;

const steps = [
  {
    title: 'Analyse',
    text: 'Relevé du parcours, lecture des obstacles, compréhension des lignes de jeu et des distances utiles.',
  },
  {
    title: 'Data',
    text: 'Structuration des mesures et des éléments cartographiques pour une base fiable et actualisable.',
  },
  {
    title: 'Production',
    text: 'Dessin vectoriel, hiérarchie visuelle et mise en page du carnet — prêt pour l’impression.',
  },
  {
    title: 'Impression',
    text: 'Tirage papier écologique, finitions premium, livraison rapide pour votre pro shop ou votre club.',
  },
];
---

<section class:list={['section-photo border-b border-mist', !teaser && 'bg-sand']}>
  {
    teaser && (
      <>
        <img
          src="/images/bg-fairway.jpg"
          alt=""
          class="section-photo-img"
          width="1280"
          height="1920"
          loading="lazy"
        />
        <div class="section-photo-veil"></div>
      </>
    )
  }
  <div class="mx-auto max-w-6xl px-5 py-20 md:px-8 md:py-28">
    <div class="reveal flex flex-col gap-6 md:flex-row md:items-end md:justify-between">
      <div class="max-w-2xl">
        <p class="text-xs font-semibold uppercase tracking-[0.2em] text-green-mid">Méthode</p>
        <h2 class="mt-3 font-display text-4xl text-ink md:text-5xl">
          Du terrain au carnet, en quatre étapes.
        </h2>
        {
          !teaser && (
            <p class="mt-4 text-base leading-relaxed text-ink-soft md:text-lg">
              Un pipeline maîtrisé pour livrer des carnets précis, cohérents d’un trou à l’autre, et adaptés
              à l’identité de votre golf.
            </p>
          )
        }
      </div>
      {
        teaser && (
          <a
            href="/methode"
            class="shrink-0 text-sm font-semibold text-green-mid underline-offset-4 hover:underline"
          >
            Voir la méthode →
          </a>
        )
      }
    </div>

    <div class="reveal reveal-delay-1 mt-14 grid gap-10 md:grid-cols-4 md:gap-6">
      {
        steps.map((step, index) => (
          <div class="relative">
            <p class="font-display text-5xl text-green-mid/25 md:text-6xl">
              {String(index + 1).padStart(2, '0')}
            </p>
            <h3 class="mt-3 font-display text-2xl text-green-mid">{step.title}</h3>
            <p class="mt-3 text-sm leading-relaxed text-ink-soft md:text-base">{step.text}</p>
          </div>
        ))
      }
    </div>
  </div>
</section>
