---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Hero from '../components/Hero.astro';
import Pillars from '../components/Pillars.astro';
import ProcessSteps from '../components/ProcessSteps.astro';
import ProductGallery from '../components/ProductGallery.astro';
import { withBase } from '../lib/paths';
---

<BaseLayout
  title="Yardage — Carnets de parcours pour golfs et pros"
  description="Yardage conçoit et produit des carnets de parcours golf pour clubs et professionnels. Précision cartographique, impression premium, devis sur mesure."
  ogImage="/images/bg-aerial.jpg"
>
  <Header />
  <main>
    <Hero />
    <Pillars />

    <section class="section-photo border-b border-mist" id="produit">
      <img
        src={withBase('/images/carnets-irl.jpg')}
        alt=""
        class="section-photo-img !opacity-30"
        width="823"
        height="795"
        loading="lazy"
      />
      <div class="section-photo-veil"></div>
      <div class="mx-auto max-w-6xl px-5 py-20 md:px-8 md:py-28">
        <div class="reveal max-w-2xl">
          <p class="text-xs font-semibold uppercase tracking-[0.2em] text-green-mid">Le produit</p>
          <h2 class="mt-3 font-display text-4xl text-ink md:text-5xl">Du dessin du parcours au carnet imprimé.</h2>
          <p class="mt-4 text-base leading-relaxed text-ink-soft md:text-lg">
            Couverture personnalisée, cartographie précise, format pensé pour le parcours. Demandez un
            <span class="text-ink">exemplaire numérique gratuit</span> pour découvrir votre golf.
          </p>
        </div>

        <ProductGallery />
      </div>
    </section>

    <ProcessSteps teaser />

    <section class="relative isolate overflow-hidden text-white">
      <img
        src={withBase('/images/bg-fairway.jpg')}
        alt=""
        class="absolute inset-0 -z-20 h-full w-full object-cover"
        width="1280"
        height="1920"
        loading="lazy"
      />
      <div class="absolute inset-0 -z-10 bg-paper/80"></div>
      <div class="reveal mx-auto max-w-6xl px-5 py-20 md:px-8 md:py-28">
        <h2 class="max-w-xl font-display text-4xl md:text-5xl">
          Un carnet digne de votre parcours.
        </h2>
        <p class="mt-4 max-w-lg text-base leading-relaxed text-white/80 md:text-lg">
          Demandez un devis ou un exemplaire numérique gratuit — nous étudions votre club et vous
          proposons une production adaptée.
        </p>
        <div class="mt-8 flex flex-wrap gap-3">
          <a
            href={withBase('/contact')}
            class="rounded-sm bg-white px-5 py-3 text-sm font-semibold text-brand transition hover:bg-ink"
          >
            Demander un devis
          </a>
          <a
            href={withBase('/contact#exemplaire')}
            class="rounded-sm border border-white/35 px-5 py-3 text-sm font-semibold text-white transition hover:bg-white/10"
          >
            Exemplaire numérique gratuit
          </a>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</BaseLayout>
