---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Hero from '../components/Hero.astro';
import Pricing from '../components/Pricing.astro';
import ProductGallery from '../components/ProductGallery.astro';
import { withBase } from '../lib/paths';
---

<BaseLayout
  title="Offre — Yardage"
  description="Tarifs Yardage pour golfs et pros : 11,90 € HT l’unité, remises volume, personnalisation logo et impression premium."
>
  <Header />
  <main>
    <Hero
      title="Offre"
      subtitle="Des carnets premium à un tarif club transparent — avec remises volume."
      image="/images/bg-trees.jpg"
      compact
    />
    <Pricing />

    <section class="section-photo border-b border-mist">
      <img
        src={withBase('/images/carnets-irl.jpg')}
        alt=""
        class="section-photo-img !opacity-30"
        width="823"
        height="795"
        loading="lazy"
      />
      <div class="section-photo-veil"></div>
      <div class="mx-auto max-w-6xl px-5 py-20 md:px-8 md:py-28">
        <div class="reveal max-w-2xl">
          <h2 class="font-display text-3xl text-ink md:text-4xl">Personnalisation</h2>
          <p class="mt-4 text-base leading-relaxed text-ink-soft md:text-lg">
            Logo du club, page sponsors, mentions partenaires — le carnet porte l’identité de votre
            structure tout en restant un outil de jeu.
          </p>
        </div>

        <ProductGallery />
      </div>
    </section>
  </main>
  <Footer />
</BaseLayout>
